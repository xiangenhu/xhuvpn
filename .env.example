# Google Cloud credentials (for local development only — not needed on Cloud Run)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# GCS bucket for VPN data (peers.json, server-keys.json)
GCS_BUCKET=your-project-id-vpn-data

# GCE VM running WireGuard
GCE_HOST=your-vm-external-ip
GCE_USER=ubuntu

# WireGuard settings
WG_INTERFACE=wg0
SERVER_PORT=51820
SERVER_ENDPOINT=vpn.yourdomain.com
VPN_SUBNET=10.8.0

# Secret Manager secret names
SSH_KEY_SECRET=vpn-ssh-private-key
API_KEY_SECRET=vpn-api-secret

# Server port (Cloud Run sets PORT automatically)
PORT=8080
